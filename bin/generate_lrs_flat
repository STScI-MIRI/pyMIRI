import sys
import platform

p_name = platform.uname().system

if p_name=='Darwin':
    miri_dir = '/Users/sshenoy/pyADpack/pyMIRI'
elif p_name=='Linux':
    miri_dir = '/home/sshenoy/pyADpack/pyMIRI'
else:
    print("Couldn't identify the os platform")
    sys.exit(1)
    
sys.path.append(miri_dir)

# from lrs import make_flat as mf
from package.pymiri.lrs import make_flat as mf

if __name__ == "__main__":
    mf.main()
    