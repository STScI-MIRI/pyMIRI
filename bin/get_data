import sys
import platform

p_name = platform.uname().system

if p_name=='Darwin':
    miri_dir = '/Users/sshenoy/pyADpack/pyMIRI'
elif p_name=='Linux':
    miri_dir = '/home/sshenoy/pyADpack/pyMIRI'
else:
    sys.exit("Couldn't identify the os platform")
    
sys.path.append(miri_dir)

from package.pymiri.utils import download_data as dd

if __name__ == "__main__":
    dd.main()